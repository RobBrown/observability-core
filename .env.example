# Required — the service name reported in traces, logs, and metrics
OTEL_SERVICE_NAME=my-service

# Required — Sentry OTLP endpoint and auth header
OTEL_SENTRY_ENDPOINT=https://o<org_id>.ingest.sentry.io/api/<project_id>/otlp/v1/traces
OTEL_SENTRY_HEADERS=X-Sentry-Auth=DSN_HERE

# Required — Honeycomb OTLP endpoint and auth header
OTEL_HONEYCOMB_ENDPOINT=https://api.honeycomb.io
OTEL_HONEYCOMB_HEADERS=x-honeycomb-team=YOUR_API_KEY

# Optional — enable debug logging for observability-core
OTEL_DEBUG=false
